# 로컬 개발 환경 설정 (localhub Busan)
VITE_APP_TITLE=localhub Busan
VITE_API_URL=http://localhost:3000/api

# 지도 API 키 설정
# 카카오 개발자 콘솔(https://developers.kakao.com/console/app)에서 발급받은 JavaScript 키를 입력하세요
# 주의: REST API 키가 아닌 JavaScript 키를 사용해야 합니다
# 
# 발급 및 설정 방법:
# 1. https://developers.kakao.com/console/app 접속
# 2. 애플리케이션 추가 또는 기존 앱 선택
# 3. 앱 키 탭에서 'JavaScript 키' 복사
# 4. 플랫폼 설정에서 Web 플랫폼 추가
# 5. 사이트 도메인에 http://localhost:5173 추가 (개발 서버 포트에 맞게 수정)
# 6. 아래에 복사한 JavaScript 키 입력
VITE_KAKAO_MAP_API_KEY=your_javascript_key_here
